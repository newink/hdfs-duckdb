# name: test/sql/hdfs_trace_settings.test
# description: test hdfs_trace_* DuckDB settings registration and type validation
# group: [sql]

require hdfs_duckdb

# ── Default values ────────────────────────────────────────────────────────────

query I
SELECT current_setting('hdfs_trace_enabled');
----
false

query I
SELECT current_setting('hdfs_trace_file_path');
----
(empty)

query I
SELECT current_setting('hdfs_trace_rotate_max_bytes');
----
10485760

# ── SET succeeds with correct types ──────────────────────────────────────────

statement ok
SET hdfs_trace_enabled = true

query I
SELECT current_setting('hdfs_trace_enabled');
----
true

statement ok
SET hdfs_trace_enabled = false

statement ok
SET hdfs_trace_file_path = '/tmp/test_hdfs_trace.jsonl'

query I
SELECT current_setting('hdfs_trace_file_path');
----
/tmp/test_hdfs_trace.jsonl

statement ok
SET hdfs_trace_rotate_max_bytes = 5242880

query I
SELECT current_setting('hdfs_trace_rotate_max_bytes');
----
5242880

# ── Type validation: wrong types are rejected ─────────────────────────────────

statement error
SET hdfs_trace_enabled = 'not_a_bool'
----
Invalid Input Error: Failed to cast value: Could not convert string 'not_a_bool' to BOOL

statement error
SET hdfs_trace_rotate_max_bytes = 'not_a_number'
----
Invalid Input Error: Failed to cast value: Could not convert string 'not_a_number' to INT64

# ── Reset to defaults ─────────────────────────────────────────────────────────

statement ok
RESET hdfs_trace_enabled

statement ok
RESET hdfs_trace_file_path

statement ok
RESET hdfs_trace_rotate_max_bytes

query I
SELECT current_setting('hdfs_trace_enabled');
----
false
