# name: test/sql/hdfs_duckdb_glob.test
# description: test hdfs_duckdb URI normalization for glob-style paths
# group: [sql]

require hdfs_duckdb

statement ok
SET hdfs_default_fs='viewfs://analytics-cluster'

query I
SELECT hdfs_duckdb_normalize_uri('hdfs:///warehouse/date=*/part-*.parquet');
----
viewfs://analytics-cluster/warehouse/date=*/part-*.parquet

query I
SELECT hdfs_duckdb_normalize_uri('hdfs://namenode:8020//warehouse/./events/../date=*/part-*.parquet');
----
hdfs://namenode:8020/warehouse/date=*/part-*.parquet
